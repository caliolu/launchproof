# ===========================================
# LaunchProof Environment Variables
# ===========================================
# Copy this to .env.local and fill in the values
# cp .env.local.example .env.local

# -------------------------------------------
# Supabase (Required)
# https://supabase.com/dashboard/project/_/settings/api
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -------------------------------------------
# Claude AI (Required for AI features)
# https://console.anthropic.com/settings/keys
# -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------
# fal.ai — Image Generation (Required for landing page images)
# https://fal.ai/dashboard/keys
# -------------------------------------------
FAL_KEY=...

# -------------------------------------------
# DataForSEO — Keyword Data (Optional, falls back to mock data)
# https://app.dataforseo.com/api-dashboard
# -------------------------------------------
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# -------------------------------------------
# PostHog — Analytics (Optional)
# https://posthog.com
# -------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -------------------------------------------
# Resend — Transactional Email (Optional)
# https://resend.com/api-keys
# -------------------------------------------
RESEND_API_KEY=re_...

# -------------------------------------------
# Stripe — Billing (Optional for free tier)
# https://dashboard.stripe.com/apikeys
# -------------------------------------------
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# -------------------------------------------
# App Configuration
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LANDING_PAGE_DOMAIN=localhost:3000
